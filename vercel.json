{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "pnpm install",
  "buildCommand": "pnpm build:website",
  "outputDirectory": "dist-website",
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/website",
      "destination": "/",
      "permanent": false
    },
    {
      "source": "/website/:path*",
      "destination": "/:path*",
      "permanent": false
    }
  ]
}
