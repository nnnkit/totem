{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm build:website",
  "outputDirectory": "dist-website",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/website/:path*",
      "destination": "/:path*",
      "permanent": false
    }
  ]
}
