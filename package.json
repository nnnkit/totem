{
  "name": "totem",
  "version": "1.1.2",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "pnpm build:extension",
    "build:extension": "tsc && vite build",
    "build:website": "vite build -c vite.website.config.ts",
    "build:all": "pnpm build:extension && pnpm build:website",
    "preview": "vite preview",
    "package:extension": "pnpm build:extension && node scripts/package-extension.mjs",
    "package:website": "pnpm build:website && node scripts/package-website.mjs",
    "package:all": "pnpm package:extension && pnpm package:website",
    "release": "node scripts/release.mjs",
    "ship": "pnpm release",
    "ship:minor": "pnpm release minor",
    "ship:major": "pnpm release major",
    "release:version:check": "node scripts/check-version-sync.mjs",
    "release:check": "pnpm release:version:check && pnpm package:extension",
    "release:prepare": "node scripts/prepare-release.mjs",
    "test": "vitest run",
    "test:reliability": "vitest run src/hooks/__tests__/sync-state-machine.test.ts src/api/__tests__/parsers.bookmarks.test.ts src/lib/__tests__/reconcile.test.ts",
    "ci:verify": "pnpm test && pnpm build"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@phosphor-icons/react": "^2.1.10",
    "clsx": "^2.1.1",
    "idb": "^8.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hotkeys-hook": "^5.2.4",
    "sugar-high": "^0.9.5",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.0.0",
    "@types/chrome": "^0.0.287",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^4.0.18"
  }
}
